# 永続データ保存先の変更
APP_DATA_DIR=""
# メトリクス連携用PrometheusのURL
PROMETHEUS_REMOTE_WRITE_URL="http://host.containers.internal:9090/api/v1/write"
# PROFILEの指定。
# monitoring=リソース監視用のprometheus-podman-exporter, alloyを起動する。
# W: COMPOSE_PROFILESによる制御は要podman-compose 1.1.0以上
COMPOSE_PROFILES="monitoring"
# サーバのドメイン名
NGINX_SERVER_NAME="nextcloud.example.com"
# SSL 証明書と秘密鍵のパス
NGINX_SSL_CERT="/path/to/ssl_cert.pem"
NGINX_SSL_CERT_KEY="/path/to/ssl_cert_privkey.pem"
