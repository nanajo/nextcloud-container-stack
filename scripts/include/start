# テンプレート標準の start.sh だけではスタートアップ処理が足りない場合、ここに追加する
#--------------#
# 設定チェック #
#--------------#
# podman secret の設定有無
config_check_secret(){
    # 検査対象の secret
    SECRETS="nextcloud_db_root_pw nextcloud_db_user_pw"
    for SECRET_NAME in ${SECRETS};
    do
        if podman secret inspect ${SECRET_NAME} > /dev/null 2>&1; then
            echo "Checking ${SECRET_NAME}. [OK]"
        else
            ERR_MSG="Checking ${SECRET_NAME}. [NG]\nCreate secret for DB password using \"podman secret create ${SECRET_NAME} /PATH/TO/PASSWORD/FILE\""
            err ${ERR_MSG}
            exit 1
        fi
    done
}

# SSL 証明書のチェックとSYMLINKの実態へのパス置き換え
# パスチェック関数
config_check_ssl_cert_chkpath() {
    # ファイルの存在チェック
    if [ -e $1 ]; then
        # シンボリックリンク対策として、realpath で実態を返す
        realpath $1
    else
        err "$1 does not exist"
    fi
}

# ファイル形式チェック
config_check_ssl_cert_chkfiletype(){
    FILE_INFO="$(file -b -- "$1")"
    case "${FILE_INFO}" in
        *"PEM certificate"*|\
        *"Certificate"*|\
        *"public key certificate"*|\
        *"private key"*|\
        *"RSA private key"*|\
        *"EC private key"*|\
        *"OpenSSH private key"*)
            echo "Checking file type of ${REAL_PATH} [OK]"
            ;;
        *)
            echo "Checking file type of ${REAL_PATH} [NG]"
            echo "${REAL_PATH} is not SSL Certificate or Private key file."
            exit 1
            ;;
    esac
}

# 証明書チェック本体
config_check_ssl_cert() {
    export NGINX_SSL_CERT=$(config_check_ssl_cert_chkpath ${NGINX_SSL_CERT})
    config_check_ssl_cert_chkfiletype ${NGINX_SSL_CERT}
    export NGINX_SSL_CERT_KEY=$(config_check_ssl_cert_chkpath ${NGINX_SSL_CERT_KEY})
    config_check_ssl_cert_chkfiletype ${NGINX_SSL_CERT_KEY}
}

#------#
# main #
#------#
config_check_secret
config_check_ssl_cert